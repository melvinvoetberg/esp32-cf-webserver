# Copy to .env and fill in your values, then: source .env

# WiFi
export WIFI_SSID="your-wifi-ssid"
export WIFI_PASS="your-wifi-password"

# Cloudflare Tunnel (from: cloudflared tunnel token <NAME>)
# Leave empty for TryCloudflare quick tunnels
export CF_TUNNEL_TOKEN=""
export CF_HOSTNAME=""

# Stable connector ID (run once: uuidgen)
export CF_CONNECTOR_ID=""
